{
  "name": "loan-management-system",
  "version": "0.1.0",
  "private": true,
  "postcss": {
    "plugins": {
      "tailwindcss": {},
      "autoprefixer": {}
    }
  },
  "scripts": {
    "dev": "npx next dev -p 3001",
    "build": "prisma generate && npx next build",
    "postinstall": "prisma generate",
    "start": "npx next start -p 3001",
    "lint": "npx next lint",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "node prisma/seed.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:regression": "node scripts/full-regression.js",
    "test:regression-alert-webhooks": "npx tsx scripts/test-regression-alert-webhooks.ts",
    "test:regression-alert-providers": "npx tsx scripts/test-regression-alert-providers.ts",
    "test:message-delivery-queue": "npx tsx scripts/test-message-delivery-queue.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^3.0.3",
    "decimal.js": "^10.4.3",
    "jose": "^5.9.6",
    "next": "14.2.18",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.8"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
