// ============================================================================
// 借款业务管理系统 — Prisma Schema v2.0
// 数据库: PostgreSQL  |  金额精度: Decimal(18,4)
// 全局规则: 所有主键 UUID、软删除、created/updatedAt
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  A — 用户与权限 (RBAC)                                                  ║
// ╚══════════════════════════════════════════════════════════════════════════╝

model User {
  id             String    @id @default(uuid())
  username       String    @unique
  passwordHash   String    @map("password_hash")
  realName       String    @map("real_name")
  phone          String?
  email          String?
  roleId         String    @map("role_id")
  isActive       Boolean   @default(true) @map("is_active")
  lastLoginAt    DateTime? @map("last_login_at")
  lastLoginIp    String?   @map("last_login_ip")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  role               Role                   @relation(fields: [roleId], references: [id])
  auditLogs          AuditLog[]
  loanApplications   LoanApplication[]      @relation("ApplicationCreator")
  approvals          LoanApproval[]         @relation("Approver")
  disbursements      Disbursement[]         @relation("DisbursementOperator")
  repayments         Repayment[]            @relation("RepaymentOperator")
  ledgerEntries      LedgerEntry[]          @relation("LedgerOperator")
  pricingRules       PricingRule[]          @relation("PricingRuleCreator")
  notifications      Notification[]         @relation("NotificationTarget")

  @@index([roleId])
  @@index([username])
  @@index([deletedAt])
  @@map("users")
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  code        String   @unique
  description String?
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users       User[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid())
  name        String
  code        String   @unique
  module      String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  roles RolePermission[]

  @@index([module])
  @@map("permissions")
}

model RolePermission {
  id           String   @id @default(uuid())
  roleId       String   @map("role_id")
  permissionId String   @map("permission_id")
  createdAt    DateTime @default(now()) @map("created_at")

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  B — 客户管理                                                           ║
// ╚══════════════════════════════════════════════════════════════════════════╝

model Customer {
  id                       String    @id @default(uuid())
  name                     String
  phone                    String    @unique
  passwordHash             String?   @map("password_hash")
  idType                   String    @default("ID_CARD") @map("id_type")
  idNumber                 String    @unique @map("id_number")
  email                    String?
  address                  String?
  emergencyContact         String?   @map("emergency_contact")
  emergencyContactPhone    String?   @map("emergency_contact_phone")
  emergencyContactRelation String?   @map("emergency_contact_relation")
  bankAccount              String?   @map("bank_account")
  bankName                 String?   @map("bank_name")
  riskLevel                String    @default("NORMAL") @map("risk_level")
  creditLimit              Decimal   @default(10000) @map("credit_limit") @db.Decimal(14,2)
  creditLimitOverride      Decimal?  @map("credit_limit_override") @db.Decimal(14,2)
  source                   String?
  remark                   String?
  createdAt                DateTime  @default(now()) @map("created_at")
  updatedAt                DateTime  @updatedAt @map("updated_at")
  deletedAt                DateTime? @map("deleted_at")

  kyc                  CustomerKyc[]
  loanApplications     LoanApplication[]
  contracts            Contract[]
  repaymentConfirms    RepaymentConfirmation[]
  overdueRecords       OverdueRecord[]
  ledgerEntries        LedgerEntry[]          @relation("CustomerLedger")
  notifications        Notification[]         @relation("CustomerNotification")

  @@index([phone])
  @@index([name])
  @@index([riskLevel])
  @@index([deletedAt])
  @@map("customers")
}

model CustomerKyc {
  id           String    @id @default(uuid())
  customerId   String    @map("customer_id")
  kycType      String    @map("kyc_type")
  documentUrl  String?   @map("document_url")
  status       String    @default("PENDING")
  verifiedAt   DateTime? @map("verified_at")
  expiresAt    DateTime? @map("expires_at")
  remark       String?
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  customer Customer @relation(fields: [customerId], references: [id])

  @@unique([customerId, kycType])
  @@index([status])
  @@map("customer_kyc")
}

// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  C — 资金方与资金管理                                                    ║
// ╚══════════════════════════════════════════════════════════════════════════╝

model Funder {
  id               String    @id @default(uuid())
  name             String    @unique
  type             String    @default("INDIVIDUAL")
  loginPhone       String?   @unique @map("login_phone")
  passwordHash     String?   @map("password_hash")
  cooperationMode  String    @default("FIXED_MONTHLY") @map("cooperation_mode")
  monthlyRate      Decimal   @default(2) @map("monthly_rate") @db.Decimal(5,2)
  weeklyRate       Decimal   @default(1.5) @map("weekly_rate") @db.Decimal(5,2)
  priority         Int       @default(0)
  riskSharing      Boolean   @default(false) @map("risk_sharing")
  riskShareRatio   Decimal   @default(0) @map("risk_share_ratio") @db.Decimal(5,4)
  withdrawalCooldownDays Int @default(0) @map("withdrawal_cooldown_days")
  contactPerson    String?   @map("contact_person")
  contactPhone     String?   @map("contact_phone")
  contactEmail     String?   @map("contact_email")
  profitShareRatio Decimal?  @map("profit_share_ratio") @db.Decimal(5, 4)
  isActive         Boolean   @default(true) @map("is_active")
  remark           String?
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")

  accounts          FundAccount[]
  profitShares      FundProfitShare[]
  withdrawalRequests FunderWithdrawal[]
  notifications      FunderNotification[]
  contracts          FunderContract[]

  @@index([deletedAt])
  @@index([priority])
  @@map("funders")
}

model FundAccount {
  id           String    @id @default(uuid())
  funderId     String    @map("funder_id")
  accountName  String    @map("account_name")
  bankName     String    @map("bank_name")
  accountNo    String    @unique @map("account_no")
  balance      Decimal   @default(0) @db.Decimal(18, 4)
  totalInflow  Decimal   @default(0) @map("total_inflow") @db.Decimal(18, 4)
  totalOutflow Decimal   @default(0) @map("total_outflow") @db.Decimal(18, 4)
  totalProfit  Decimal   @default(0) @map("total_profit") @db.Decimal(18, 4)
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  funder        Funder          @relation(fields: [funderId], references: [id])
  inflows       CapitalInflow[]
  disbursements Disbursement[]

  @@index([funderId])
  @@map("fund_accounts")
}

model CapitalInflow {
  id            String    @id @default(uuid())
  fundAccountId String    @map("fund_account_id")
  amount        Decimal   @db.Decimal(18, 4)
  channel       String    @default("BANK_TRANSFER")
  inflowDate    DateTime  @map("inflow_date")
  status        String    @default("PENDING")
  remark        String?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  fundAccount FundAccount @relation(fields: [fundAccountId], references: [id])

  @@index([fundAccountId])
  @@index([inflowDate])
  @@index([status])
  @@map("capital_inflows")
}

model FundProfitShare {
  id           String   @id @default(uuid())
  funderId     String   @map("funder_id")
  periodStart  DateTime @map("period_start")
  periodEnd    DateTime @map("period_end")
  totalInterest Decimal @map("total_interest") @db.Decimal(18, 4)
  shareRatio   Decimal  @map("share_ratio") @db.Decimal(5, 4)
  shareAmount  Decimal  @map("share_amount") @db.Decimal(18, 4)
  status       String   @default("PENDING")
  settledAt    DateTime? @map("settled_at")
  remark       String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  funder Funder @relation(fields: [funderId], references: [id])

  @@index([funderId])
  @@index([periodStart, periodEnd])
  @@index([status])
  @@map("fund_profit_shares")
}

model FunderWithdrawal {
  id            String    @id @default(uuid())
  funderId      String    @map("funder_id")
  accountId     String?   @map("account_id")
  amount        Decimal   @db.Decimal(18, 4)
  type          String    @default("INTEREST")
  status        String    @default("PENDING")
  includeInterest Boolean @default(true) @map("include_interest")
  interestAmount Decimal  @default(0) @map("interest_amount") @db.Decimal(18, 4)
  approvedAt    DateTime? @map("approved_at")
  approvedBy    String?   @map("approved_by")
  rejectedAt    DateTime? @map("rejected_at")
  rejectedReason String?  @map("rejected_reason")
  remark        String?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  funder Funder @relation(fields: [funderId], references: [id])

  @@index([funderId])
  @@index([status])
  @@map("funder_withdrawals")
}

model FunderNotification {
  id        String   @id @default(uuid())
  funderId  String   @map("funder_id")
  type      String   @default("INFO")
  title     String
  content   String
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  funder Funder @relation(fields: [funderId], references: [id])

  @@index([funderId, isRead])
  @@index([createdAt])
  @@map("funder_notifications")
}

model FunderContract {
  id              String   @id @default(uuid())
  funderId        String   @map("funder_id")
  cooperationMode String   @map("cooperation_mode")
  title           String
  content         String
  signedAt        DateTime? @map("signed_at")
  status          String   @default("DRAFT")
  generatedBy     String?  @map("generated_by")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  funder Funder @relation(fields: [funderId], references: [id])

  @@index([funderId])
  @@index([status])
  @@map("funder_contracts")
}

// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  D — 产品与定价                                                         ║
// ╚══════════════════════════════════════════════════════════════════════════╝

model LoanProduct {
  id                String    @id @default(uuid())
  name              String    @unique
  code              String    @unique
  description       String?
  minAmount         Decimal   @map("min_amount") @db.Decimal(18, 4)
  maxAmount         Decimal   @map("max_amount") @db.Decimal(18, 4)
  minTermValue      Int       @map("min_term_value")
  maxTermValue      Int       @map("max_term_value")
  termUnit          String    @default("MONTH") @map("term_unit")
  repaymentMethod   String    @map("repayment_method")
  allowEarlyRepay   Boolean   @default(true) @map("allow_early_repay")
  allowExtension    Boolean   @default(false) @map("allow_extension")
  maxExtensionTimes Int       @default(0) @map("max_extension_times")
  isActive          Boolean   @default(true) @map("is_active")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  deletedAt         DateTime? @map("deleted_at")

  pricingRules     PricingRule[]
  loanApplications LoanApplication[]

  @@index([isActive])
  @@index([deletedAt])
  @@map("loan_products")
}

model PricingRule {
  id              String   @id @default(uuid())
  productId       String   @map("product_id")
  name            String
  ruleType        String   @map("rule_type")
  rateType        String   @map("rate_type")
  rateValue       Decimal  @map("rate_value") @db.Decimal(10, 6)
  minValue        Decimal? @map("min_value") @db.Decimal(18, 4)
  maxValue        Decimal? @map("max_value") @db.Decimal(18, 4)
  conditionJson   String?  @map("condition_json")
  priority        Int      @default(0)
  isActive        Boolean  @default(true) @map("is_active")
  effectiveFrom   DateTime @map("effective_from")
  effectiveTo     DateTime? @map("effective_to")
  version         Int      @default(1)
  createdById     String?  @map("created_by_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  product   LoanProduct @relation(fields: [productId], references: [id])
  createdBy User?       @relation("PricingRuleCreator", fields: [createdById], references: [id])

  @@index([productId, isActive])
  @@index([ruleType])
  @@index([effectiveFrom, effectiveTo])
  @@map("pricing_rules")
}

// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  E — 借款申请与审批                                                      ║
// ╚══════════════════════════════════════════════════════════════════════════╝

model LoanApplication {
  id                  String    @id @default(uuid())
  applicationNo       String    @unique @map("application_no")
  customerId          String    @map("customer_id")
  productId           String    @map("product_id")
  amount              Decimal   @db.Decimal(18, 4)
  termValue           Int       @map("term_value")
  termUnit            String    @default("MONTH") @map("term_unit")
  purpose             String?
  status              String    @default("DRAFT")
  riskScore           Decimal?  @map("risk_score") @db.Decimal(5, 2)
  riskComment         String?   @map("risk_comment")
  totalApprovedAmount Decimal?  @map("total_approved_amount") @db.Decimal(18, 4)
  approvedAt          DateTime? @map("approved_at")
  rejectedAt          DateTime? @map("rejected_at")
  rejectedReason      String?   @map("rejected_reason")
  createdById         String    @map("created_by_id")
  remark              String?
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  deletedAt           DateTime? @map("deleted_at")

  customer     Customer          @relation(fields: [customerId], references: [id])
  product      LoanProduct       @relation(fields: [productId], references: [id])
  createdBy    User              @relation("ApplicationCreator", fields: [createdById], references: [id])
  approvals    LoanApproval[]
  contracts    Contract[]
  disbursement Disbursement?

  @@index([customerId])
  @@index([productId])
  @@index([status])
  @@index([applicationNo])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("loan_applications")
}

model LoanApproval {
  id              String    @id @default(uuid())
  applicationId   String    @map("application_id")
  approverId      String    @map("approver_id")
  level           Int       @default(1)
  action          String
  approvedAmount  Decimal?  @map("approved_amount") @db.Decimal(18, 4)
  conditions      String?
  comment         String?
  createdAt       DateTime  @default(now()) @map("created_at")

  application LoanApplication @relation(fields: [applicationId], references: [id])
  approver    User            @relation("Approver", fields: [approverId], references: [id])

  @@index([applicationId])
  @@index([approverId])
  @@map("loan_approvals")
}

// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  F — 合同管理                                                           ║
// ╚══════════════════════════════════════════════════════════════════════════╝

model ContractTemplate {
  id           String    @id @default(uuid())
  name         String
  code         String    @unique
  content      String
  variables    String[]
  version      Int       @default(1)
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  contracts Contract[]

  @@index([isActive])
  @@index([deletedAt])
  @@map("contract_templates")
}

model Contract {
  id              String    @id @default(uuid())
  contractNo      String    @unique @map("contract_no")
  contractType    String    @default("MAIN") @map("contract_type")
  applicationId   String    @map("application_id")
  customerId      String    @map("customer_id")
  templateId      String    @map("template_id")
  content         String
  variableData    String?   @map("variable_data")
  status          String    @default("DRAFT")
  signedAt        DateTime? @map("signed_at")
  effectiveDate   DateTime? @map("effective_date")
  expiryDate      DateTime? @map("expiry_date")
  version         Int       @default(1)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  application LoanApplication  @relation(fields: [applicationId], references: [id])
  customer    Customer         @relation(fields: [customerId], references: [id])
  template    ContractTemplate @relation(fields: [templateId], references: [id])
  signatures  Signature[]

  @@index([applicationId])
  @@index([customerId])
  @@index([status])
  @@index([contractType])
  @@index([deletedAt])
  @@map("contracts")
}

model Signature {
  id              String   @id @default(uuid())
  contractId      String   @map("contract_id")
  signerType      String   @map("signer_type")
  signerName      String   @map("signer_name")
  signatureData   String   @map("signature_data")
  screenshotUrl   String?  @map("screenshot_url")
  ipAddress       String   @map("ip_address")
  deviceInfo      String?  @map("device_info")
  locationInfo    String?  @map("location_info")
  signedAt        DateTime @default(now()) @map("signed_at")
  createdAt       DateTime @default(now()) @map("created_at")

  contract Contract @relation(fields: [contractId], references: [id])

  @@index([contractId])
  @@map("signatures")
}

// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  G — 放款                                                              ║
// ╚══════════════════════════════════════════════════════════════════════════╝

model Disbursement {
  id                String    @id @default(uuid())
  disbursementNo    String    @unique @map("disbursement_no")
  applicationId     String    @unique @map("application_id")
  fundAccountId     String    @map("fund_account_id")
  amount            Decimal   @db.Decimal(18, 4)
  feeAmount         Decimal   @default(0) @map("fee_amount") @db.Decimal(18, 4)
  netAmount         Decimal   @map("net_amount") @db.Decimal(18, 4)
  batchNo           String?   @map("batch_no")
  feeDetailJson     String?   @map("fee_detail_json")
  payerAccount      String?   @map("payer_account")
  payerBank         String?   @map("payer_bank")
  status            String    @default("PENDING")
  disbursedAt       DateTime? @map("disbursed_at")
  customerConfirmIp String?   @map("customer_confirm_ip")
  operatorId        String    @map("operator_id")
  remark            String?
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  application LoanApplication @relation(fields: [applicationId], references: [id])
  fundAccount FundAccount     @relation(fields: [fundAccountId], references: [id])
  operator    User            @relation("DisbursementOperator", fields: [operatorId], references: [id])

  @@index([fundAccountId])
  @@index([status])
  @@index([disbursedAt])
  @@index([batchNo])
  @@map("disbursements")
}

// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  H — 还款计划与还款                                                      ║
// ╚══════════════════════════════════════════════════════════════════════════╝

model RepaymentPlan {
  id                  String    @id @default(uuid())
  planNo              String    @unique @map("plan_no")
  applicationId       String    @map("application_id")
  totalPrincipal      Decimal   @map("total_principal") @db.Decimal(18, 4)
  totalInterest       Decimal   @map("total_interest") @db.Decimal(18, 4)
  totalFee            Decimal   @default(0) @map("total_fee") @db.Decimal(18, 4)
  totalPeriods        Int       @default(1) @map("total_periods")
  rulesSnapshotJson   String?   @map("rules_snapshot_json")
  status              String    @default("ACTIVE")
  supersededBy        String?   @map("superseded_by")
  version             Int       @default(1)
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  scheduleItems RepaymentScheduleItem[]
  repayments    Repayment[]

  @@index([applicationId])
  @@index([status])
  @@map("repayment_plans")
}

model RepaymentScheduleItem {
  id              String    @id @default(uuid())
  planId          String    @map("plan_id")
  periodNumber    Int       @map("period_number")
  dueDate         DateTime  @map("due_date")
  principal       Decimal   @db.Decimal(18, 4)
  interest        Decimal   @db.Decimal(18, 4)
  fee             Decimal   @default(0) @db.Decimal(18, 4)
  totalDue        Decimal   @map("total_due") @db.Decimal(18, 4)
  remaining       Decimal   @default(0) @db.Decimal(18, 4)
  status          String    @default("PENDING")
  paidAt          DateTime? @map("paid_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  plan RepaymentPlan @relation(fields: [planId], references: [id])

  @@index([planId])
  @@index([dueDate])
  @@index([status])
  @@map("repayment_schedule_items")
}

model Repayment {
  id              String    @id @default(uuid())
  repaymentNo     String    @unique @map("repayment_no")
  planId          String    @map("plan_id")
  amount          Decimal   @db.Decimal(18, 4)
  principalPart   Decimal   @map("principal_part") @db.Decimal(18, 4)
  interestPart    Decimal   @map("interest_part") @db.Decimal(18, 4)
  feePart         Decimal   @default(0) @map("fee_part") @db.Decimal(18, 4)
  penaltyPart     Decimal   @default(0) @map("penalty_part") @db.Decimal(18, 4)
  paymentMethod   String    @map("payment_method")
  status          String    @default("PENDING")
  matchComment    String?   @map("match_comment")
  receivedAt      DateTime? @map("received_at")
  operatorId      String    @map("operator_id")
  remark          String?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  plan         RepaymentPlan        @relation(fields: [planId], references: [id])
  operator     User                 @relation("RepaymentOperator", fields: [operatorId], references: [id])
  allocations  RepaymentAllocation[]
  confirmation RepaymentConfirmation?

  @@index([planId])
  @@index([status])
  @@index([receivedAt])
  @@map("repayments")
}

model RepaymentAllocation {
  id          String  @id @default(uuid())
  repaymentId String  @map("repayment_id")
  itemId      String  @map("item_id")
  amount      Decimal @db.Decimal(18, 4)
  type        String
  createdAt   DateTime @default(now()) @map("created_at")

  repayment Repayment @relation(fields: [repaymentId], references: [id])

  @@index([repaymentId])
  @@index([itemId])
  @@map("repayment_allocations")
}

model RepaymentConfirmation {
  id               String    @id @default(uuid())
  repaymentId      String    @unique @map("repayment_id")
  customerId       String    @map("customer_id")
  signatureData    String?   @map("signature_data")
  ipAddress        String    @map("ip_address")
  deviceInfo       String?   @map("device_info")
  status           String    @default("PENDING")
  rejectReason     String?   @map("reject_reason")
  confirmedAt      DateTime? @map("confirmed_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  repayment Repayment @relation(fields: [repaymentId], references: [id])
  customer  Customer  @relation(fields: [customerId], references: [id])

  @@index([customerId])
  @@index([status])
  @@map("repayment_confirmations")
}

// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  I — 逾期管理                                                           ║
// ╚══════════════════════════════════════════════════════════════════════════╝

model OverdueRecord {
  id               String    @id @default(uuid())
  customerId       String    @map("customer_id")
  applicationId    String    @map("application_id")
  scheduleItemId   String    @map("schedule_item_id")
  overdueAmount    Decimal   @map("overdue_amount") @db.Decimal(18, 4)
  penaltyAmount    Decimal   @default(0) @map("penalty_amount") @db.Decimal(18, 4)
  overdueDays      Int       @default(0) @map("overdue_days")
  gracePeriodDays  Int       @default(0) @map("grace_period_days")
  overdueFeeDetail String?   @map("overdue_fee_detail")
  status           String    @default("OVERDUE")
  resolvedAt       DateTime? @map("resolved_at")
  remark           String?
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  customer Customer @relation(fields: [customerId], references: [id])

  @@index([customerId])
  @@index([applicationId])
  @@index([status])
  @@index([overdueDays])
  @@map("overdue_records")
}

// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  J — 展期 & 重组                                                        ║
// ╚══════════════════════════════════════════════════════════════════════════╝

model Extension {
  id              String    @id @default(uuid())
  applicationId   String    @map("application_id")
  extensionTimes  Int       @default(1) @map("extension_times")
  originalDueDate DateTime  @map("original_due_date")
  newDueDate      DateTime  @map("new_due_date")
  extensionDays   Int       @map("extension_days")
  extensionFee    Decimal   @default(0) @map("extension_fee") @db.Decimal(18, 4)
  applyReason     String?   @map("apply_reason")
  status          String    @default("PENDING")
  approvedAt      DateTime? @map("approved_at")
  remark          String?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([applicationId])
  @@index([status])
  @@map("extensions")
}

model Restructure {
  id                 String    @id @default(uuid())
  applicationId      String    @map("application_id")
  oldPlanId          String?   @map("old_plan_id")
  remainingPrincipal Decimal   @map("remaining_principal") @db.Decimal(18, 4)
  remainingInterest  Decimal   @map("remaining_interest") @db.Decimal(18, 4)
  newTermValue       Int       @map("new_term_value")
  newTermUnit        String    @default("MONTH") @map("new_term_unit")
  newRate            Decimal   @map("new_rate") @db.Decimal(10, 6)
  applyReason        String?   @map("apply_reason")
  status             String    @default("PENDING")
  approvedAt         DateTime? @map("approved_at")
  remark             String?
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  @@index([applicationId])
  @@index([status])
  @@map("restructures")
}

// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  K — 财务总账                                                           ║
// ╚══════════════════════════════════════════════════════════════════════════╝

model LedgerEntry {
  id            String   @id @default(uuid())
  entryNo       String   @unique @map("entry_no")
  type          String
  direction     String   @default("DEBIT")
  amount        Decimal  @db.Decimal(18, 4)
  balanceBefore Decimal  @map("balance_before") @db.Decimal(18, 4)
  balanceAfter  Decimal  @map("balance_after") @db.Decimal(18, 4)
  referenceType String   @map("reference_type")
  referenceId   String   @map("reference_id")
  customerId    String?  @map("customer_id")
  operatorId    String?  @map("operator_id")
  description   String?
  createdAt     DateTime @default(now()) @map("created_at")

  customer Customer? @relation("CustomerLedger", fields: [customerId], references: [id])
  operator User?     @relation("LedgerOperator", fields: [operatorId], references: [id])

  @@index([type])
  @@index([referenceType, referenceId])
  @@index([customerId])
  @@index([operatorId])
  @@index([createdAt])
  @@index([direction])
  @@map("ledger_entries")
}

// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  L — 审计日志                                                           ║
// ╚══════════════════════════════════════════════════════════════════════════╝

model AuditLog {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  action         String
  entityType     String   @map("entity_type")
  entityId       String   @map("entity_id")
  oldValue       String?  @map("old_value")
  newValue       String?  @map("new_value")
  changeSummary  String?  @map("change_summary")
  isAmountChange Boolean  @default(false) @map("is_amount_change")
  ipAddress      String?  @map("ip_address")
  userAgent      String?  @map("user_agent")
  createdAt      DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entityType, entityId])
  @@index([action])
  @@index([createdAt])
  @@index([isAmountChange])
  @@map("audit_logs")
}

// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  M — 附件 & 通知 & 系统设置                                              ║
// ╚══════════════════════════════════════════════════════════════════════════╝

model Attachment {
  id           String    @id @default(uuid())
  entityType   String    @map("entity_type")
  entityId     String    @map("entity_id")
  fileName     String    @map("file_name")
  fileUrl      String    @map("file_url")
  fileSize     Int       @map("file_size")
  mimeType     String    @map("mime_type")
  category     String    @default("GENERAL")
  uploadedBy   String    @map("uploaded_by")
  createdAt    DateTime  @default(now()) @map("created_at")
  deletedAt    DateTime? @map("deleted_at")

  @@index([entityType, entityId])
  @@index([category])
  @@index([deletedAt])
  @@map("attachments")
}

model Notification {
  id           String    @id @default(uuid())
  userId       String?   @map("user_id")
  customerId   String?   @map("customer_id")
  type         String
  templateCode String?   @map("template_code")
  title        String
  content      String
  status       String    @default("PENDING")
  retryCount   Int       @default(0) @map("retry_count")
  isRead       Boolean   @default(false) @map("is_read")
  readAt       DateTime? @map("read_at")
  sentAt       DateTime? @map("sent_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  user     User?     @relation("NotificationTarget", fields: [userId], references: [id])
  customer Customer? @relation("CustomerNotification", fields: [customerId], references: [id])

  @@index([userId, isRead])
  @@index([customerId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
  @@map("notifications")
}

model MessageDelivery {
  id                String    @id @default(uuid())
  sourceType        String?   @map("source_type")
  sourceId          String?   @map("source_id")
  audience          String
  targetId          String    @map("target_id")
  targetName        String    @map("target_name")
  channel           String
  provider          String
  event             String
  templateCode      String?   @map("template_code")
  title             String
  content           String
  recipientPhone    String?   @map("recipient_phone")
  recipientEmail    String?   @map("recipient_email")
  status            String    @default("PENDING")
  attemptCount      Int       @default(0) @map("attempt_count")
  maxAttempts       Int       @default(5) @map("max_attempts")
  nextRetryAt       DateTime? @map("next_retry_at")
  lastAttemptAt     DateTime? @map("last_attempt_at")
  deliveredAt       DateTime? @map("delivered_at")
  lastError         String?   @map("last_error")
  providerMessageId String?   @map("provider_message_id")
  durationMs        Int?      @map("duration_ms")
  payloadJson       String?   @map("payload_json")
  metadataJson      String?   @map("metadata_json")
  responseJson      String?   @map("response_json")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  attempts MessageDeliveryAttempt[]

  @@index([status, nextRetryAt])
  @@index([channel, provider, createdAt])
  @@index([sourceType, sourceId])
  @@index([targetId, createdAt])
  @@index([event])
  @@map("message_deliveries")
}

model MessageDeliveryAttempt {
  id            String   @id @default(uuid())
  deliveryId    String   @map("delivery_id")
  channel       String
  provider      String
  attemptNo     Int      @map("attempt_no")
  status        String
  startedAt     DateTime @map("started_at")
  finishedAt    DateTime? @map("finished_at")
  durationMs    Int?     @map("duration_ms")
  requestJson   String?  @map("request_json")
  responseJson  String?  @map("response_json")
  errorMessage  String?  @map("error_message")
  createdAt     DateTime @default(now()) @map("created_at")

  delivery MessageDelivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)

  @@index([deliveryId, createdAt])
  @@index([provider, status, createdAt])
  @@map("message_delivery_attempts")
}

model SystemSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  group     String   @default("GENERAL")
  remark    String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([group])
  @@map("system_settings")
}
