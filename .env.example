# ============================================================
# 借款业务管理系统 — 环境变量配置
# 复制本文件为 .env 并填入实际值
# ============================================================

# ── 数据库（Supabase PostgreSQL） ──
# 连接池地址（应用运行时）：Supabase 控制台 → Project Settings → Database → Connection Pooling
# 格式：postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
# 直连地址（Prisma migrate/seed）：Supabase 控制台 → Project Settings → Database → Connection string
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# ── Supabase API ──
# Supabase 控制台 → Project Settings → API
# Project URL
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
# anon (public) key — 前端可用
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGci..."
# service_role key — 仅服务端使用，绝对不要暴露到前端
SUPABASE_SERVICE_ROLE_KEY="eyJhbGci..."

# ── 认证 ──
# JWT 签名密钥（生产环境请用 openssl rand -base64 32 生成随机值）
JWT_SECRET="change-me-in-production"

# ── CORS ──
# 允许跨域请求的前端域名（逗号分隔）
# 开发环境下 localhost 会自动放行，无需额外配置
ALLOWED_ORIGINS="https://your-production-domain.com"
